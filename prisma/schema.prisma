generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EquipmentType {
  PLASMA
  GAS
}

enum SupplyCategory {
  CONSUMABLE
  FIXTURE
}

enum SupplyDepartment {
  CUTTING   // 절단
  FACILITY  // 공무
}

// ── 스케줄러 ──────────────────────────────────────────────

enum ScheduleWorkType {
  NORMAL    // 일반
  REVISION  // 도면개정
}

enum ScheduleHoldReason {
  MATERIAL_DELAY  // 강재지연
  URGENT          // 긴급작업
  REVISION        // 도면개정
  OTHER           // 기타
}

enum ScheduleStatus {
  PLANNED       // 예정
  IN_PROGRESS   // 진행중
  COMPLETED     // 완료
  HOLD          // 홀드
  CANCELLED     // 취소
}

enum UrgentWorkStatus {
  PENDING      // 대기
  IN_PROGRESS  // 진행중
  COMPLETED    // 완료
}

// ── 잔재 관리 ──────────────────────────────────────────────

enum RemnantType {
  REMNANT    // 잔재 (정규 작업 후 남은 자투리)
  SURPLUS    // 여유재 (입고했지만 미사용 판재)
  REGISTERED // 등록잔재 (도면번호 부여, 사용 전 협의 필요)
}

enum RemnantShape {
  RECTANGLE  // 사각형
  L_SHAPE    // L자형
  STRIP      // 띠형
  IRREGULAR  // 불규칙형
}

enum RemnantStatus {
  IN_STOCK   // 재고있음
  IN_USE     // 사용중
  EXHAUSTED  // 소진
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ProjectType {
  A
  B
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum WorkOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CuttingStatus {
  STARTED    // 절단 진행중
  COMPLETED  // 절단 완료
}

enum DrawingStatus {
  REGISTERED  // 등록 (Excel 업로드)
  WAITING     // 대기 (입고 완료)
  CUT         // 절단 (작업일보 등록)
}

// Excel 업로드 형식 프리셋
model ExcelPreset {
  id            String   @id @default(cuid())
  name          String   // 프리셋 이름 (제공업체명 or 형식명)
  dataStartRow  Int      @default(2) // 데이터 시작 행번호 (1-indexed)
  colBlock      Int?     // 블록 열번호
  colDrawingNo  Int?     // 도면/NEST 열번호
  colHeatNo     Int?     // Heat NO 열번호
  colMaterial   Int?     // 재질 열번호
  colThickness  Int?     // 두께 열번호
  colWidth      Int?     // 폭 열번호
  colLength     Int?     // 길이 열번호
  colQty        Int?     // 수량 열번호
  colSteelWeight Int?    // 강재중량 열번호
  colUseWeight  Int?     // 사용중량 열번호
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 호선(프로젝트) 마스터
model Project {
  id          String        @id @default(cuid())
  projectCode String
  projectName String
  type        ProjectType
  client      String
  status      ProjectStatus @default(ACTIVE)
  memo        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  drawingLists DrawingList[]
  workOrders   WorkOrder[]
  cuttingLogs  CuttingLog[]
  schedules    CncSchedule[]
  urgentWorks  UrgentWork[]
  remnants     Remnant[]

  @@unique([projectCode, projectName])
}

// 강재리스트 (Excel 업로드 파싱)
model DrawingList {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  block       String?
  drawingNo   String?
  heatNo      String?
  material    String
  thickness   Float
  width       Float
  length      Float
  qty         Int
  steelWeight Float?
  useWeight   Float?
  sourceFile  String?
  status      DrawingStatus @default(REGISTERED)
  receivedAt  DateTime?     // 입고일 (대기 상태로 변경 시 자동 기록)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrders  WorkOrder[]
  cuttingLogs CuttingLog[]
}

// 작업지시 (내부 참조용 유지)
model WorkOrder {
  id            String          @id @default(cuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawingListId String?
  drawingList   DrawingList?    @relation(fields: [drawingListId], references: [id])
  equipmentId   String?
  equipment     Equipment?      @relation(fields: [equipmentId], references: [id])

  orderNo       String          @unique
  status        WorkOrderStatus @default(PENDING)
  priority      Priority        @default(NORMAL)
  assignedAt    DateTime?
  dueDate       DateTime?
  memo          String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// 절단 작업일보
model CuttingLog {
  id            String        @id @default(cuid())
  equipmentId   String
  equipment     Equipment     @relation(fields: [equipmentId], references: [id])
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  drawingListId String?
  drawingList   DrawingList?  @relation(fields: [drawingListId], references: [id], onDelete: SetNull)

  heatNo        String        // Heat NO (필수)
  material      String?       // 재질 (도면에서 자동입력)
  thickness     Float?        // 두께 (도면에서 자동입력)
  width         Float?        // 폭 (도면에서 자동입력)
  length        Float?        // 길이 (도면에서 자동입력)
  qty           Int?          // 수량 (도면에서 자동입력)
  drawingNo     String?       // 도면번호 (도면에서 자동입력)
  operator      String        // 작업자명 (필수)
  status        CuttingStatus @default(STARTED)
  startAt       DateTime      @default(now())
  endAt         DateTime?     // 절단 종료 시각
  memo          String?

  // 돌발작업 연결 (기존 컬럼 불변 원칙)
  isUrgent      Boolean       @default(false)
  urgentWorkId  String?
  urgentWork    UrgentWork?   @relation(fields: [urgentWorkId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// 인원 마스터
model Worker {
  id            String    @id @default(cuid())
  name          String                        // 이름
  nationality   String?                       // 국적
  birthDate     DateTime?                     // 생년월일
  phone         String?                       // 전화번호
  role          String?                       // 담당
  position      String?                       // 직책
  joinDate      DateTime?                     // 입사일
  bloodType     String?                       // 혈액형
  shoeSize      String?                       // 신발사이즈
  winterTop     String?                       // 동복 상의
  winterBottom  String?                       // 동복 하의
  summerTop     String?                       // 하계 상의
  summerBottom  String?                       // 하계 하의
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 장비 마스터
model Equipment {
  id             String          @id @default(cuid())
  name           String
  type           EquipmentType
  status         EquipmentStatus @default(ACTIVE)
  lastInspection DateTime?
  nextInspection DateTime?
  memo           String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workOrders     WorkOrder[]
  cuttingLogs    CuttingLog[]
}

// ==========================================
// 구매/자재 파트 (소모품, 비품, 거래처, 입출고)
// ==========================================

model SupplyItem {
  id           Int              @id @default(autoincrement())
  name         String           // 품명
  category     SupplyCategory   // 물품 구분 (소모품/비품)
  department   SupplyDepartment @default(CUTTING) // 관리주체 (절단/공무)
  subCategory  String?          // 세부분류
  unit         String           // 단위 (개, 통, 켤레 등)
  stockQty     Int              @default(0) // 현재 재고 수량
  reorderPoint Int?             // 발주 기준점 (소모품 전용)
  location     String?          // 보관 위치
  memo         String?          // 비고

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  inbounds     SupplyInbound[]
  outbounds    SupplyOutbound[]
}

model SupplyInbound {
  id           Int         @id @default(autoincrement())
  itemId       Int
  item         SupplyItem  @relation(fields: [itemId], references: [id])
  vendorId     Int?
  vendor       Vendor?     @relation(fields: [vendorId], references: [id])
  qty          Int         // 입고 수량
  receivedBy   String      // 입고 담당자
  receivedAt   DateTime    @default(now()) // 입고 일시
  memo         String?     // 비고

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SupplyOutbound {
  id           Int         @id @default(autoincrement())
  itemId       Int
  item         SupplyItem  @relation(fields: [itemId], references: [id])
  qty          Int         // 출고 수량
  usedBy       String      // 사용자
  usedAt       DateTime    @default(now()) // 출고 일시
  memo         String?     // 비고

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Vendor {
  id             Int         @id @default(autoincrement())
  name           String      // 업체명
  contact        String?     // 담당자명
  phone          String?     // 연락처
  email          String?     // 이메일
  businessNumber String?     // 사업자번호
  category       String?     // 주요 취급 품목 카테고리
  memo           String?     // 비고

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  inbounds     SupplyInbound[]
}

// ==========================================
// 스케줄러 모듈
// ==========================================

model CncSchedule {
  id               String              @id @default(cuid())

  // 기존 블록 연결 (자재 등록 전 선행 생성 가능하므로 nullable)
  projectId        String?
  project          Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // 자재 미등록 상태에서 직접 입력하는 경우
  vesselCode       String              // 호선 코드
  blockName        String              // 블록명

  plannedStart     DateTime?           // 절단 시작 예정일
  plannedEnd       DateTime?           // 절단 완료 예정일
  deliveryFactory  DateTime?           // 가공장 납기일
  deliveryAssembly DateTime?           // 조립장 납기일

  workType         ScheduleWorkType    @default(NORMAL)
  status           ScheduleStatus      @default(PLANNED)
  holdReason       ScheduleHoldReason? // 중단 사유 (홀드 시)

  priority         Int                 @default(0)   // 낮을수록 우선
  memo             String?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model UrgentWork {
  id           String           @id @default(cuid())
  urgentNo     String           @unique  // URG-2026-001 자동채번
  title        String           // 작업명
  urgency      String           @default("URGENT")  // URGENT / FLEXIBLE / PRECUT

  requester    String?          // 요청자
  department   String?          // 부서

  // 호선/블록 연관
  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vesselName   String?          // 직접 입력 호선명

  requestDate  DateTime         @default(now())
  dueDate      DateTime?

  materialMemo String?          // 재질 메모 (자유 텍스트)
  drawingNo    String?          // 도면번호
  destination  String?          // 도착지

  // 사용 예정 잔재 연결
  remnantId    String?
  remnant      Remnant?         @relation(fields: [remnantId], references: [id], onDelete: SetNull)

  status       UrgentWorkStatus @default(PENDING)
  registeredBy String?
  memo         String?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  cuttingLogs  CuttingLog[]
}

// ── 잔재 모델 ──────────────────────────────────────────────

model Remnant {
  id           String        @id @default(cuid())
  remnantNo    String        @unique  // REM-2026-001 자동채번

  type         RemnantType
  shape        RemnantShape

  material     String        // 재질
  thickness    Float         // 두께 (mm)
  weight       Float         // 중량 (kg)

  // 치수 (형태별 입력)
  width1       Float?        // W 또는 W1 (사각형·L자형 전체폭·띠형폭)
  length1      Float?        // L 또는 L1 (사각형·L자형 전체길이·띠형길이)
  width2       Float?        // W2 (L자형 절단폭)
  length2      Float?        // L2 (L자형 절단길이)

  // 발생 출처
  sourceProjectId  String?
  sourceProject    Project?  @relation(fields: [sourceProjectId], references: [id], onDelete: SetNull)
  sourceVesselName String?   // 직접 입력 호선명

  // 보관 및 기타
  location     String?       // 보관 위치
  photoUrl     String?       // 사진
  status       RemnantStatus @default(IN_STOCK)
  registeredBy String        // 등록자

  // 등록잔재 전용
  originalVesselName String? // 원래 호선명
  drawingNo          String? // 도면번호
  consultPerson      String? // 협의 담당자
  needsConsult       Boolean @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  urgentWorks  UrgentWork[]
}
