generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EquipmentType {
  PLASMA
  GAS
}

enum SupplyCategory {
  CONSUMABLE
  FIXTURE
}

enum SupplyDepartment {
  CUTTING // 절단
  FACILITY // 공무
}

// ── 스케줄러 ──────────────────────────────────────────────

enum ScheduleWorkType {
  NORMAL // 일반
  REVISION // 도면개정
}

enum ScheduleHoldReason {
  MATERIAL_DELAY // 강재지연
  URGENT // 긴급작업
  REVISION // 도면개정
  OTHER // 기타
}

enum ScheduleStatus {
  PLANNED // 예정
  IN_PROGRESS // 진행중
  COMPLETED // 완료
  HOLD // 홀드
  CANCELLED // 취소
}

enum UrgentWorkStatus {
  PENDING // 대기
  IN_PROGRESS // 진행중
  COMPLETED // 완료
}

// ── 잔재 관리 ──────────────────────────────────────────────

enum RemnantType {
  REMNANT // 현장잔재 (정규 작업 후 남은 자투리)
  SURPLUS // 여유원재 (입고했지만 미사용 판재)
  REGISTERED // 등록잔재 (등록된 잔재)
}

enum RemnantShape {
  RECTANGLE // 사각형
  L_SHAPE // L자형
  IRREGULAR // 불규칙형
}

enum RemnantStatus {
  PENDING // 등록 (초기 등록, 원철판 미절단)
  IN_STOCK // 재고 (원철판 절단완료, 판번호 부여됨)
  EXHAUSTED // 소진 (다른 곳에 사용됨)
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ProjectType {
  A
  B
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum WorkOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CuttingStatus {
  STARTED   // 절단 진행중
  PAUSED    // 절단 중단
  COMPLETED // 절단 완료
}

enum PauseReason {
  EQUIPMENT_FAILURE    // 장비고장
  DRAWING_CHANGE       // 도면변경
  CONSUMABLE           // 소모품교체
  WORK_EXTENSION       // 작업연장
  OTHER                // 기타(직접입력)
}

enum DrawingStatus {
  REGISTERED // 대기 (SteelPlan 있으나 미입고)
  WAITING // 입고완료 (SteelPlan 매칭 + 입고)
  CAUTION // 주의 (SteelPlan에 없는 항목)
  CUT // 절단 (작업일보 등록)
}

enum SteelPlanStatus {
  REGISTERED  // 등록 (계획 등록)
  RECEIVED    // 입고완료
  ISSUED      // 절단장 투입 (내부 출고)
  COMPLETED   // 절단완료 (cutting-logs complete 시 자동 전환, 역순 취소 가드 대상)
  SHIPPED_OUT // 외부 출고 (납품처로 발송 — Shipment 생성 시 전환)
}

enum SteelPlanHeatStatus {
  WAITING // 대기
  CUT     // 절단
  SHIPPED // 외부 출고
}

enum ShipmentStatus {
  ACTIVE
  CANCELLED
}

// Excel 업로드 형식 프리셋
model ExcelPreset {
  id             String   @id @default(cuid())
  name           String // 프리셋 이름 (제공업체명 or 형식명)
  dataStartRow   Int      @default(2) // 데이터 시작 행번호 (1-indexed)
  colBlock       Int? // 블록 열번호
  colDrawingNo   Int? // 도면/NEST 열번호
  colHeatNo      Int? // Heat NO 열번호
  colMaterial    Int? // 재질 열번호
  colThickness   Int? // 두께 열번호
  colWidth       Int? // 폭 열번호
  colLength      Int? // 길이 열번호
  colQty         Int? // 수량 열번호
  colSteelWeight Int? // 강재중량 열번호
  colUseWeight   Int? // 사용중량 열번호
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 호선(프로젝트) 마스터
model Project {
  id              String        @id @default(cuid())
  projectCode     String
  projectName     String
  type            ProjectType
  client          String?
  status          ProjectStatus @default(ACTIVE)
  memo            String?
  storageLocation String? // 보관 위치 (야드 구역)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  drawingLists DrawingList[]
  workOrders   WorkOrder[]
  cuttingLogs  CuttingLog[]
  schedules    CncSchedule[]
  urgentWorks  UrgentWork[]
  remnants     Remnant[]
  bomItems     BomItem[]
  cuttingPdfs  CuttingDrawingPdf[]

  @@unique([projectCode, projectName])
}

// 블록별 절단도면 PDF (Phase A — 보관/미리보기/인쇄/다운로드)
model CuttingDrawingPdf {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  block       String? // 업로드 시 사용자가 지정한 블록 (null = 미지정)
  filename    String // 원본 파일명
  storedName  String // 디스크 저장명 (cuid.pdf)
  pageCount   Int      @default(1)
  fileSize    Int // bytes
  presetId    String? // Phase B: 어느 프리셋으로 추출했는지
  preset      CuttingDrawingPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  extracted   Json? // Phase B: 마지막 추출 결과 스냅샷
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  extractions CuttingDrawingExtraction[]

  @@index([projectId, block])
}

// 절단도면 PDF 추출 프리셋 (Phase B — 설계업체별 양식)
model CuttingDrawingPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  vendor      String?
  description String?
  method      String   @default("TEXT") // "TEXT" (pdfjs textContent) | "OCR" (Tesseract.js)
  rules       Json // { detectKeywords: [...], drawingNo: {label,valuePattern}, partWeight: {...}, markingLen: {...}, cuttingLen: {...} }
  sampleUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pdfs        CuttingDrawingPdf[]
  extractions CuttingDrawingExtraction[]
}

// 절단도면 PDF 페이지별 추출 결과 (Phase B — 별도 보관, DrawingList 와 분리)
model CuttingDrawingExtraction {
  id         String   @id @default(cuid())
  pdfId      String
  pdf        CuttingDrawingPdf @relation(fields: [pdfId], references: [id], onDelete: Cascade)
  presetId   String?
  preset     CuttingDrawingPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  pageNumber Int
  drawingNo  String? // 도면번호 (예: F11CNCP01, B16C-CNX01)
  partWeight Float? // 부재중량 (Kg)
  markingLen Float? // 마킹길이 (M)
  cuttingLen Float? // 절단길이 (M)
  method     String // "TEXT" | "OCR" | "MANUAL"
  confidence Float? // OCR 평균 신뢰도 (0~1)
  rawText    String? // 추출 디버그용 페이지 raw text (앞부분 일부)
  notes      String? // 사용자 메모/수정 사유
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pdfId, pageNumber])
  @@index([pdfId])
}

// BOM 업체 프리셋 (업체별 엑셀 컬럼 매핑 설정)
model BomVendor {
  id        String   @id @default(cuid())
  name      String   @unique // 업체명
  desc      String? // 설명
  preset    Json // 파싱 설정 (header_row, project_cell, block_cell, filter, fields, ...)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bomItems BomItem[]
}

// BOM 항목 (업체 엑셀 파싱 후 DB 저장)
model BomItem {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId  String?
  vendor    BomVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  hosin      String // 호선
  block      String // 블록
  partName   String // 파트명
  thickness  String? // 두께 (문자열, dim_parse 결과 포함)
  size       String? // 사이즈
  material   String? // 재질
  process    String? // 가공
  qty        Int? // 수량
  weight     Float? // 중량(kg)
  nestNo     String? // NEST NO
  sourceFile String? // 원본 파일명

  createdAt DateTime @default(now())
}

// 강재리스트 (Excel 업로드 파싱)
model DrawingList {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  block               String?
  drawingNo           String?
  heatNo              String?
  material            String
  thickness           Float
  width               Float
  length              Float
  qty                 Int
  steelWeight         Float?
  useWeight           Float?
  cutLength           Float?  // 절단길이 (mm) — 절단도면 PDF 추출
  markingLength       Float?  // 마킹길이 (mm) — 절단도면 PDF 추출
  sourcePdfId         String? // 출처 CuttingDrawingPdf.id (역참조)
  sourcePdfPage       Int?    // 멀티페이지 PDF 중 어느 페이지
  sourceFile          String?
  status              DrawingStatus @default(REGISTERED)
  receivedAt          DateTime? // 입고일 (대기 상태로 변경 시 자동 기록)
  alternateVesselCode String? // 대체호선: 비어있으면 자기 호선 재고, 있으면 해당 호선 재고에서 매칭
  hasRemnant          Boolean       @default(false) // 등록잔재 발생 여부

  // 등록잔재 사용 절단: 어떤 잔재를 사용하는지 (있으면 하단 잔재사용 리스트)
  assignedRemnantId String?
  assignedRemnant   Remnant? @relation("AssignedRemnant", fields: [assignedRemnantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrders  WorkOrder[]
  cuttingLogs CuttingLog[]
  remnants    Remnant[]
}

// 작업지시 (내부 참조용 유지)
model WorkOrder {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawingListId String?
  drawingList   DrawingList? @relation(fields: [drawingListId], references: [id])
  equipmentId   String?
  equipment     Equipment?   @relation(fields: [equipmentId], references: [id])

  orderNo    String          @unique
  status     WorkOrderStatus @default(PENDING)
  priority   Priority        @default(NORMAL)
  assignedAt DateTime?
  dueDate    DateTime?
  memo       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 절단 작업일보
model CuttingLog {
  id            String       @id @default(cuid())
  equipmentId   String
  equipment     Equipment    @relation(fields: [equipmentId], references: [id])
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  drawingListId String?
  drawingList   DrawingList? @relation(fields: [drawingListId], references: [id], onDelete: SetNull)

  heatNo    String // Heat NO (필수)
  material  String? // 재질 (도면에서 자동입력)
  thickness Float? // 두께 (도면에서 자동입력)
  width     Float? // 폭 (도면에서 자동입력)
  length    Float? // 길이 (도면에서 자동입력)
  qty       Int? // 수량 (도면에서 자동입력)
  drawingNo String? // 도면번호 (도면에서 자동입력)
  operator  String // 작업자명 (필수)
  status    CuttingStatus @default(STARTED)
  startAt   DateTime      @default(now())
  endAt     DateTime? // 절단 종료 시각
  memo      String?

  // 돌발작업 연결 (기존 컬럼 불변 원칙)
  isUrgent     Boolean     @default(false)
  urgentWorkId String?
  urgentWork   UrgentWork? @relation(fields: [urgentWorkId], references: [id], onDelete: SetNull)

  pauses    CuttingPause[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 절단 중단 기록
model CuttingPause {
  id           String       @id @default(cuid())
  cuttingLogId String
  cuttingLog   CuttingLog   @relation(fields: [cuttingLogId], references: [id], onDelete: Cascade)
  reason       PauseReason
  reasonText   String?      // OTHER 선택 시 직접 입력 내용
  pausedAt     DateTime     @default(now())
  resumedAt    DateTime?    // 재개 시각 (null = 아직 중단 중)
  createdAt    DateTime     @default(now())
}

// 근무지 옵션
model WorksiteOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// 인원 마스터
model Worker {
  id           String    @id @default(cuid())
  name         String // 이름
  nationality  String? // 국적
  birthDate    DateTime? // 생년월일
  phone        String? // 전화번호
  role         String? // 담당
  position     String? // 직책
  worksite     String? // 근무지
  carNumber    String? // 차량번호
  joinDate     DateTime? // 입사일
  bloodType    String? // 혈액형
  shoeSize     String? // 신발사이즈
  winterTop    String? // 동복 상의
  winterBottom String? // 동복 하의
  summerTop    String? // 하계 상의
  summerBottom String? // 하계 하의
  isCncOp      Boolean   @default(false) // CNC 플라즈마 운전 가능 여부
  // 외국인 전용 필드
  nickname     String? // 닉네임
  englishName  String? // 영문이름
  visaType     String? // 비자타입
  foreignIdNo  String? // 외국인등록증번호
  passportNo   String? // 여권번호
  visaExpiry   DateTime? // 비자만기일
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// 식수 관리
model MealVendor {
  id              String       @id @default(cuid())
  name            String
  factory         String // 진교 / 진동
  phone           String?
  pricePerMeal    Int?
  token           String       @unique
  deadlineHour    Int          @default(10)
  deadlineMin     Int          @default(0)
  defaultCount    Int          @default(0)
  defaultMealType String       @default("점심")
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  records         MealRecord[]
}

model MealRecord {
  id        String      @id @default(cuid())
  date      String // YYYY-MM-DD
  factory   String // 진교 / 진동
  mealType  String      @default("점심")
  count     Int
  memo      String?
  registrar String?
  vendorId  String?
  vendor    MealVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([date, factory, mealType])
}

// 식수 월별 결산
model MealSettlement {
  id          String   @id @default(cuid())
  factory     String // 진교 / 진동
  month       String // YYYY-MM
  totalCount  Int      @default(0)
  totalAmount Int      @default(0)
  confirmedAt DateTime @default(now())
  confirmedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([factory, month])
}

// 시설관리 — 가스설비 일일점검
model GasFacilityCheck {
  id          String   @id @default(cuid())
  date        String // YYYY-MM-DD
  time        String // HH:MM
  o2Pressure  Float? // 액화산소 압력
  o2Charge    Float? // 액화산소 충전량
  lpgPressure Float? // LPG 압력
  lpgCharge   Float? // LPG 충전량
  co2Pressure Float? // CO2 압력
  co2Charge   Float? // CO2 충전량
  memo        String?
  recordedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// 시설관리 — 컴프레셔 일일점검 (1호/2호/3호)
model CompressorCheck {
  id         String   @id @default(cuid())
  date       String // YYYY-MM-DD
  time       String // HH:MM
  runtime1   Float? // 운전시간 1호
  runtime2   Float?
  runtime3   Float?
  pressure1  Float? // 토출압력 1호
  pressure2  Float?
  pressure3  Float?
  temp1      Float? // 온도 1호
  temp2      Float?
  temp3      Float?
  visual1    String? // 외관검사 1호 (양호/불량 등)
  visual2    String?
  visual3    String?
  memo       String?
  recordedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
}

// 현장 운행일지 — 출발지/도착지 위치 프리셋 (출발·도착 공용)
model DrivingLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// 결제관리 — 법인카드 마스터
model CorporateCard {
  id        String   @id @default(cuid())
  cardNo    String   @unique // 끝 4자리
  label     String? // 카드 별칭 (선택)
  createdAt DateTime @default(now())
}

// 결제관리 — 법인카드 사용대장
model CardUsage {
  id        String   @id @default(cuid())
  usedDate  String // YYYY-MM-DD
  cardNo    String // 끝 4자리
  category  String? // 구분: 사무실 / 현장
  detail    String // 사용내역
  amount    Int // 금액
  userName  String? // 사용자
  confirmed Boolean  @default(false) // 확인
  memo      String? // 비고
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usedDate])
}

// 장비 마스터
model Equipment {
  id             String          @id @default(cuid())
  name           String
  type           EquipmentType
  status         EquipmentStatus @default(ACTIVE)
  lastInspection DateTime?
  nextInspection DateTime?
  memo           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrders  WorkOrder[]
  cuttingLogs CuttingLog[]
}

// ==========================================
// 구매/자재 파트 (소모품, 비품, 거래처, 입출고)
// ==========================================

model SupplyItem {
  id           Int              @id @default(autoincrement())
  name         String // 품명
  category     SupplyCategory // 물품 구분 (소모품/비품)
  department   SupplyDepartment @default(CUTTING) // 관리주체 (절단/공무)
  subCategory  String? // 세부분류
  unit         String // 단위 (개, 통, 켤레 등)
  stockQty     Int              @default(0) // 현재 재고 수량
  reorderPoint Int? // 발주 기준점 (소모품 전용)
  location     String? // 보관 위치
  memo         String? // 비고

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inbounds  SupplyInbound[]
  outbounds SupplyOutbound[]
}

model SupplyInbound {
  id            Int        @id @default(autoincrement())
  itemId        Int
  item          SupplyItem @relation(fields: [itemId], references: [id])
  vendorId      Int?
  vendor        Vendor?    @relation(fields: [vendorId], references: [id])
  qty           Int // 입고 수량
  stockQtyAfter Int? // 입고 후 총재고 스냅샷
  receivedBy    String // 입고 담당자
  receivedAt    DateTime   @default(now()) // 입고 일시
  memo          String? // 비고

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplyOutbound {
  id            Int        @id @default(autoincrement())
  itemId        Int
  item          SupplyItem @relation(fields: [itemId], references: [id])
  qty           Int // 출고 수량
  stockQtyAfter Int? // 출고 후 총재고 스냅샷
  usedBy        String // 사용자
  usedAt        DateTime   @default(now()) // 출고 일시
  memo          String? // 비고

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vendor {
  id             Int     @id @default(autoincrement())
  name           String // 업체명
  factory        String  @default("공용") // 담당공장: '진교' / '진동' / '공용'
  contact        String? // 담당자명
  phone          String? // 연락처 (휴대폰)
  landline       String? // 일반전화 (사무실)
  fax            String? // FAX 번호
  email          String? // 이메일
  businessNumber String? // 사업자번호
  category       String? // 주요 취급 품목 카테고리
  memo           String? // 비고
  isFavorite     Boolean @default(false) // 즐겨찾기

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inbounds SupplyInbound[]
}

// ==========================================
// 스케줄러 모듈
// ==========================================

model CncSchedule {
  id String @id @default(cuid())

  // 기존 블록 연결 (자재 등록 전 선행 생성 가능하므로 nullable)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // 자재 미등록 상태에서 직접 입력하는 경우
  vesselCode String // 호선 코드
  blockName  String // 블록명

  plannedStart     DateTime? // 절단 시작 예정일
  plannedEnd       DateTime? // 절단 완료 예정일
  deliveryFactory  DateTime? // 가공장 납기일
  deliveryAssembly DateTime? // 조립장 납기일

  workType   ScheduleWorkType    @default(NORMAL)
  status     ScheduleStatus      @default(PLANNED)
  holdReason ScheduleHoldReason? // 중단 사유 (홀드 시)

  priority Int     @default(0) // 낮을수록 우선
  memo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UrgentWork {
  id       String @id @default(cuid())
  urgentNo String @unique // URG-2026-001 자동채번
  title    String // 작업명
  urgency  String @default("URGENT") // URGENT / FLEXIBLE / PRECUT

  requester  String? // 요청자
  department String? // 부서

  // 호선/블록 연관
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vesselName String? // 직접 입력 호선명

  requestDate DateTime  @default(now())
  dueDate     DateTime?

  materialMemo String? // 재질 메모 (자유 텍스트)
  drawingNo    String? // 도면번호
  destination  String? // 도착지
  useWeight    Float?  // 사용 중량 (kg) — 돌발작업 부재의 예상 절단 사용량

  // 사용 예정 잔재 연결
  remnantId String?
  remnant   Remnant? @relation(fields: [remnantId], references: [id], onDelete: SetNull)

  status       UrgentWorkStatus @default(PENDING)
  registeredBy String?
  memo         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cuttingLogs CuttingLog[]
}

// ── 잔재 모델 ──────────────────────────────────────────────

// ==========================================
// 관리 파트 — 장비관리
// ==========================================

// 장비 종류 프리셋 (사용자 추가 가능)
model MgmtEquipmentKindPreset {
  id        String @id @default(cuid())
  label     String @unique // 표시 이름 (예: CNC설비, 크레인)
  sortOrder Int    @default(0)
}

enum MgmtEquipmentUsage {
  IN_USE // 사용중
  MAINTENANCE // 점검중
  DISPOSED // 폐기
}

// 장비 마스터 (관리 파트 전용)
model MgmtEquipment {
  id           String             @id @default(cuid())
  code         String             @unique // EQP-001 자동채번
  managementNo String? // 관리번호 (외부 부여 관리번호, 선택)
  name         String // 장비명
  kind         String // 장비 종류 (MgmtEquipmentKindPreset.label 참조)
  maker        String? // 제조사
  modelName    String? // 모델명
  madeYear     Int? // 제조년도
  acquiredAt   DateTime? // 취득일
  acquiredCost Int? // 취득금액
  location     String? // 설치 위치
  usage        MgmtEquipmentUsage @default(IN_USE)
  memo         String? // 비고
  photoUrl1    String? // 장비 사진 1 (클라이언트 압축 후 /uploads/equipment/{id}/1.jpg)
  photoUrl2    String? // 장비 사진 2

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specs       MgmtEquipmentSpec[]
  inspections MgmtInspectionItem[]
  repairs     MgmtRepairLog[]
}

// 사양 (항목명 + 값 쌍)
model MgmtEquipmentSpec {
  id          String        @id @default(cuid())
  equipmentId String
  equipment   MgmtEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  specKey     String // 항목명
  specValue   String // 값
  sortOrder   Int           @default(0)
}

// 검사 항목 (한 장비에 여러 개)
model MgmtInspectionItem {
  id              String        @id @default(cuid())
  equipmentId     String
  equipment       MgmtEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  itemName        String // 검사 항목명
  periodMonth     Int // 주기 (월)
  lastInspectedAt DateTime? // 최종 검사일
  nextInspectAt   DateTime? // 다음 검사 예정일 (자동계산)
  inspector       String? // 담당 기관/담당자
  memo            String? // 비고

  logs MgmtInspectionLog[]
}

// 검사 이력 (누적 보관, 삭제 금지)
model MgmtInspectionLog {
  id          String             @id @default(cuid())
  itemId      String
  item        MgmtInspectionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  completedAt DateTime // 완료일
  memo        String?

  createdAt DateTime @default(now())
}

// 수선 이력 (누적 보관, 삭제 금지)
model MgmtRepairLog {
  id          String        @id @default(cuid())
  equipmentId String
  equipment   MgmtEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  repairedAt  DateTime // 수선일
  cause       String? // 고장 원인
  content     String // 조치 내용
  contractor  String? // 수선 업체/담당자
  cost        Int? // 비용 (레거시 — costs 합계가 우선)
  downtimeMinutes Int? // 비가동시간 (분)
  memo        String? // 비고

  costs MgmtRepairCost[]

  createdAt DateTime @default(now())
}

// 수선 소모비용 라인 아이템 (한 수선이력에 여러 비용 항목)
model MgmtRepairCost {
  id        String        @id @default(cuid())
  repairId  String
  repair    MgmtRepairLog @relation(fields: [repairId], references: [id], onDelete: Cascade)
  itemName  String // 항목명 (예: 부품비, 인건비)
  amount    Int // 금액
  sortOrder Int           @default(0)

  createdAt DateTime @default(now())
}

// ==========================================
// 랜딩페이지 — 공지사항 & 전달사항
// ==========================================

enum NoticeCategory {
  NOTICE // 공지사항
  MANAGEMENT // 경영진/관리자 전달사항
}

model Notice {
  id       String         @id @default(cuid())
  category NoticeCategory
  title    String
  content  String
  author   String
  isPinned Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 관리 파트 — 조직도 & 비상연락망
// ==========================================

// 조직도 레이아웃 (Worker 테이블 미수정 — workerId는 plain string)
model OrgChartNode {
  id       String  @id @default(cuid())
  workerId String  @unique // Worker.id 참조 (plain String, 인원 테이블 구조 불변)
  x        Float   @default(0)
  y        Float   @default(0)
  parentId String? // 상위 노드의 workerId (상하관계)
  visible  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 비상연락망 그룹
model EmergencyGroup {
  id        String @id @default(cuid())
  name      String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts EmergencyContact[]
}

// 비상연락망 항목
model EmergencyContact {
  id          String         @id @default(cuid())
  groupId     String
  group       EmergencyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  workerId    String? // Worker.id 참조 (plain String, 인원 테이블 구조 불변)
  directName  String? // 직접 입력 이름 (외부 기관용)
  directPhone String? // 직접 입력 연락처 (외부 기관용)
  sortOrder   Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 관리 파트 — 운송관리
// ==========================================

enum TransportVehicleType {
  VEHICLE // 일반차량
  EQUIPMENT // 운송장비
}

enum TransportUsage {
  IN_USE // 사용중
  MAINTENANCE // 점검중
  DISPOSED // 폐기
}

enum TransportFactory {
  FACTORY1 // 진교
  FACTORY2 // 진동
}

enum FuelType {
  GASOLINE // 휘발유
  DIESEL // 경유
  LPG // LPG
  ELECTRIC // 전기
}

enum EquipSubType {
  FORKLIFT // 지게차
  CRANE // 크레인 차량
  OTHER // 기타
}

enum TransportPowerType {
  ENGINE // 엔진
  ELECTRIC // 전동
  LPG // LPG
}

enum ConsumableBasis {
  MILEAGE // 주행거리
  PERIOD // 기간
  BOTH // 둘 다
}

// 운송차량/장비 마스터
model TransportVehicle {
  id              String               @id @default(cuid())
  code            String               @unique // VEH-001 자동채번
  vehicleType     TransportVehicleType
  name            String // 차량/장비명
  plateNo         String? // 차량번호(번호판)
  maker           String? // 제조사
  modelName       String? // 모델명
  madeYear        Int? // 연식
  acquiredAt      DateTime? // 취득일
  acquiredCost    Int? // 취득금액
  factory         TransportFactory // 보관 공장
  factoryLocation String? // 세부 위치
  manager         String? // 담당자
  usage           TransportUsage       @default(IN_USE)
  memo            String? // 비고

  // 일반차량 전용
  fuelType        FuelType? // 연료 종류
  displacement    Int? // 배기량 (cc)
  mileage         Int? // 현재 주행거리 (km)
  insuranceExpiry DateTime? // 보험 만료일
  inspExpiry      DateTime? // 정기검사 만료일

  // 운송장비 전용
  equipSubType EquipSubType? // 장비 세부 종류
  maxLoad      Float? // 최대 하중 (톤)
  powerType    TransportPowerType? // 동력 방식
  mastHeight   Float? // 마스트 높이 (m, 지게차)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specs          TransportVehicleSpec[]
  consumables    TransportConsumable[]
  consumableLogs TransportConsumableLog[]
  inspections    TransportInspectionItem[]
  repairs        TransportRepairLog[]
  drivingLogs    TransportDrivingLog[]
}

// 기타 사양 (운송장비 전용)
model TransportVehicleSpec {
  id        String           @id @default(cuid())
  vehicleId String
  vehicle   TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  specKey   String
  specValue String
  sortOrder Int              @default(0)
}

// 소모품 교체 주기 (일반차량 전용)
model TransportConsumable {
  id                  String           @id @default(cuid())
  vehicleId           String
  vehicle             TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  itemName            String // 소모품명
  basis               ConsumableBasis // 교체 기준 종류
  intervalKm          Int? // 교체 기준값 (km)
  intervalMonth       Int? // 교체 기준값 (월)
  lastReplacedAt      DateTime? // 최종 교체일
  lastReplacedMileage Int? // 최종 교체 시 주행거리
  nextReplaceMileage  Int? // 다음 교체 예정 주행거리 (자동계산)
  nextReplaceAt       DateTime? // 다음 교체 예정일 (자동계산)
  sortOrder           Int              @default(0)

  logs TransportConsumableLog[]
}

// 소모품 교체 이력 (누적 보관, 삭제 금지)
model TransportConsumableLog {
  id           String              @id @default(cuid())
  consumableId String
  consumable   TransportConsumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)
  vehicleId    String
  vehicle      TransportVehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  replacedAt   DateTime // 교체일
  mileageAt    Int? // 교체 시 주행거리
  memo         String?

  createdAt DateTime @default(now())
}

// 운송장비 정기검사 항목 (운송장비 전용)
model TransportInspectionItem {
  id              String           @id @default(cuid())
  vehicleId       String
  vehicle         TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  itemName        String // 검사 항목명
  periodMonth     Int // 주기 (월)
  lastInspectedAt DateTime? // 최종 검사일
  nextInspectAt   DateTime? // 다음 검사 예정일 (자동계산)
  inspector       String? // 담당 기관/담당자
  memo            String?

  logs TransportInspectionLog[]
}

// 운송장비 검사 이력 (누적 보관, 삭제 금지)
model TransportInspectionLog {
  id          String                  @id @default(cuid())
  itemId      String
  item        TransportInspectionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  completedAt DateTime
  memo        String?

  createdAt DateTime @default(now())
}

// 수선/정비 이력 (공통, 누적 보관, 삭제 금지)
model TransportRepairLog {
  id         String           @id @default(cuid())
  vehicleId  String
  vehicle    TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  repairedAt DateTime // 수선일
  content    String // 수선 내용
  contractor String? // 수선 업체/담당자
  cost       Int? // 비용
  memo       String?

  createdAt DateTime @default(now())
}

// 용차 사용대장 (외부 차량 임대 사용 내역)
model CharterUsage {
  id          String   @id @default(cuid())
  date        DateTime // 사용일자
  driverName  String // 운전자 이름
  driverPhone String? // 전화번호
  vehicleNo   String? // 차량번호
  items       String? // 출고품목
  departure   String? // 출발지 (DrivingLocation 프리셋 또는 직접입력)
  waypoint    String? // 경유지 (선택사항 — 사용자가 +경유지 버튼으로 추가 시)
  destination String? // 도착지
  departTime  String? // 출발시간 HH:MM
  cost        Int? // 용차비용 (원)
  memo        String? // 비고

  createdAt DateTime @default(now())
}

// 운송 운전자 마스터 (일반차량/용차 운전자 풀)
// — 차량운행일지 driver, 용차사용 driverName 자동완성용
// — 기존 string 컬럼과 FK 로 연결하지 않음 (자유 입력 + 자동완성 선택)
enum TransportDriverType {
  REGULAR // 일반차량 운전자 (이름만)
  CHARTER // 용차 운전자 (이름 + 차량번호 + 전화번호)
}

model TransportDriver {
  id        String              @id @default(cuid())
  type      TransportDriverType
  name      String
  vehicleNo String? // CHARTER 일 때만 의미 — 등록 시 자동입력 소스
  phoneNo   String? // CHARTER 일 때만 의미
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, name])
  @@index([type])
}

// 차량 운행일지
model TransportDrivingLog {
  id           String           @id @default(cuid())
  vehicleId    String
  vehicle      TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date         DateTime // 운행일
  driver       String // 운전자
  departure    String? // 출발지
  destination  String? // 도착지
  purpose      String? // 목적/용무
  startTime    String? // 출발시간 HH:MM
  endTime      String? // 도착시간 HH:MM
  startMileage Int? // 출발 전 주행거리 (km)
  endMileage   Int? // 도착 후 주행거리 (km)
  fuelCost     Int?   // 유류비(원) — legacy, 미사용 (주유량으로 대체)
  fuelLiters   Float? // 주유량 (L)
  tollCost     Int?   // 통행료 (원)
  memo         String?

  createdAt DateTime @default(now())
}

// ==========================================
// L/B 생산계획 모듈
// ==========================================

// 호선별 공정 소요일수 설정 (DB 관리, 하드코딩 금지)
model LbProcessSetting {
  id         String  @id @default(cuid())
  vesselCode String  @unique // 호선번호 (예: 4506)
  isDefault  Boolean @default(false) // 기본값 여부

  cutLeadDays Float @default(7) // 절단 선행일수 (조립착수일 기준)
  cutDuration Float @default(5) // 절단 기간 (일)

  assemblySmallDays Float @default(10) // 소조 소요일수
  assemblyMidDays   Float @default(10) // 중조 소요일수
  assemblyLargeDays Float @default(15) // 대조 소요일수

  hullInspLeadDays         Float @default(3) // 대조F 이후 최소 여유일수 (선각검사 배정 기준)
  hullInspIntervalDays     Float @default(7) // 선각검사 주기 (일)
  hullInspBlocksPerSession Float @default(2) // 회당 검사 블록 수
  paintLeadDays            Float @default(2) // 도장 착수 선행일수 (선각검사 기준)
  paintDuration            Float @default(7) // 도장 기간
  peLeadDays               Float @default(1) // P-E 착수 선행일수 (도장완료 기준)
  peDuration               Float @default(3) // P-E 기간

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 공장 캘린더 — 비작업일 등록
enum LbHolidayType {
  LEGAL // 법정공휴일 (고정일)
  SUBSTITUTE // 대체공휴일
  COMPANY // 회사 자체 휴무 (하계/동계 등)
  RAIN // 장마/우천 (야드 공정에만 적용)
  VACATION // 회사 휴가 (기간 지정)
}

model LbCalendarDay {
  id        String        @id @default(cuid())
  date      String // YYYY-MM-DD
  type      LbHolidayType
  label     String // 설명 (신정, 설날, 하계휴가 등)
  year      Int // 필터용
  createdAt DateTime      @default(now())

  @@unique([date, type])
}

// LB 생산계획 버전 관리
model LbPlanVersion {
  id               String   @id @default(cuid())
  name             String // 버전명 (예: "2026-04-03 14:32 저장본")
  isDeployed       Boolean  @default(false) // 배포 여부 (L/B확인 탭에 표시)
  blockCount       Int      @default(0) // 블록 수
  settingsSnapshot Json? // 스냅샷: processSettings + dataStartRow
  createdAt        DateTime @default(now())

  plans LbPlan[]
}

// LB 생산계획 (호선 + 블록 단위)
model LbPlan {
  id         String @id @default(cuid())
  vesselCode String // 호선번호 (예: 4506)
  blk        String // BLK 번호
  no         Int? // 순번
  weeklyQty  Int? // 주당생산량 (자유 입력)

  // 직접 입력값
  erectionDate  DateTime? // 탑재일 (조선소 납기)
  assemblyStart DateTime? // 조립착수일

  // 자동계산값 (DB 저장)
  pnd          DateTime? // PND = 탑재일 - 1일
  cutS         DateTime? // 절단 S
  cutF         DateTime? // 절단 F
  smallS       DateTime? // 소조 S
  smallF       DateTime? // 소조 F
  midS         DateTime? // 중조 S
  midF         DateTime? // 중조 F
  largeS       DateTime? // 대조 S
  largeF       DateTime? // 대조 F (= 탑재일)
  hullInspDate DateTime? // 선각검사
  paintStart   DateTime? // 도장 착수
  paintEnd     DateTime? // 도장 완료
  peStart      DateTime? // P-E 착수
  peEnd        DateTime? // P-E 완료
  delayDays    Int? // 지연일수 (PND - P-E완료)
  manualFields Json? // 수동수정된 필드명 목록 (예: ["cutS", "hullInspDate"])

  // 버전 연결
  versionId String?
  version   LbPlanVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)

  // 메타
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Remnant {
  id        String @id @default(cuid())
  remnantNo String @unique // REM-2026-001 자동채번

  type  RemnantType
  shape RemnantShape

  material  String // 재질
  thickness Float // 두께 (mm)
  weight    Float // 중량 (kg)

  // 치수 (형태별 입력)
  width1  Float? // W 또는 W1 (사각형·L자형 전체폭)
  length1 Float? // L 또는 L1 (사각형·L자형 전체길이)
  width2  Float? // W2 (L자형 절단폭)
  length2 Float? // L2 (L자형 절단길이)

  // 발생 출처
  sourceProjectId  String?
  sourceProject    Project? @relation(fields: [sourceProjectId], references: [id], onDelete: SetNull)
  sourceVesselName String? // 직접 입력 호선명
  sourceBlock      String? // 직접 입력 블록 번호

  // DrawingList 연결 (원철판 → 등록잔재, cascade 삭제)
  drawingListId String?
  drawingList   DrawingList? @relation(fields: [drawingListId], references: [id], onDelete: Cascade)

  // 부모 등록잔재 연결 (등록잔재 → 자식 등록잔재)
  parentRemnantId String?
  parentRemnant   Remnant?  @relation("RemnantTree", fields: [parentRemnantId], references: [id], onDelete: SetNull)
  childRemnants   Remnant[] @relation("RemnantTree")

  // 발생 판번호 (원철판 절단완료 시 자동 기입)
  heatNo String?

  // 보관 및 기타
  location     String? // 보관 위치
  photoUrl     String? // 사진
  memo         String? // 메모사항
  status       RemnantStatus @default(PENDING)
  reservedFor  String? // 확정된 호선/블록 (예: "RS01/F50P") — 일괄확정 시 채워지면 선점됨
  registeredBy String // 등록자

  // 레거시 필드 (미사용, 데이터 보존용)
  originalVesselName String?
  drawingNo          String?
  consultPerson      String?
  needsConsult       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  urgentWorks     UrgentWork[]
  assignedToLists DrawingList[] @relation("AssignedRemnant")
}

// ==========================================
// 원자재 공정 — 전체 자재 계획
// ==========================================

model SteelPlan {
  id                 String          @id @default(cuid())
  vesselCode         String // 호선
  material           String // 재질 (예: AH36, SS400)
  thickness          Float // 두께 (mm)
  width              Float // 폭 (mm)
  length             Float // 길이 (mm)
  status             SteelPlanStatus @default(REGISTERED)
  receivedAt         DateTime? // 입고 처리일
  selectionPrintedAt DateTime? // 선별지시서 출력일
  issuedAt           DateTime? // 출고 처리일 (절단장 투입일)
  actualHeatNo       String? // 레거시 필드 (사용 안 함)
  actualVesselCode   String? // 레거시 필드 (사용 안 함)
  actualDrawingNo    String? // 레거시 필드 (사용 안 함)
  memo               String?
  storageLocation    String? // 보관위치
  sourceFile         String? // 업로드 파일명
  uploadBatchNo      String? // 업로드 배치번호 (YYMMDDHHMMSS, 같은 업로드끼리 공유)
  reservedFor        String? // 확정 블록 (예: "B80C")

  // 외부 출고 선별 확정 (출고등록) — 판번호 확인 후 선별지시서 출력 시 마킹.
  // 상태(status)는 입고(RECEIVED) 유지하며, 확정정보에 빨간 "출고"로 표시. 되돌리기 가능.
  shipoutMarkedAt    DateTime? // 출고 확정(선별) 시각
  shipoutHeatNo      String?   // 출고 확정 시 입력한 판번호 (추적용)
  shipoutLabel       String?   // 확정정보 표시 라벨 (예: 매칭이름). null이면 호선코드로 대체

  // 외부 출고 (Shipment) 관계 — 한 SteelPlan 은 한 번 출고됨
  shipmentItems ShipmentItem[]  // 출고 이력 (ACTIVE 1건만 의미 있음 — application 강제)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 출고등록 판번호 매칭(사양+상태 동등 + FIFO) 조회 성능
  @@index([vesselCode, material, status, thickness, width, length])
}

model SteelPlanHeat {
  id            String              @id @default(cuid())
  vesselCode    String // 호선
  material      String // 재질
  thickness     Float // 두께 (mm)
  width         Float // 폭 (mm)
  length        Float // 길이 (mm)
  heatNo        String // 판번호
  status        SteelPlanHeatStatus @default(WAITING)
  cutAt         DateTime? // 절단 완료일 (CUT 전환 시 기록, WAITING 복원 시 초기화)
  shippedAt     DateTime? // 외부 출고일 (SHIPPED 전환 시 기록, 복원 시 초기화)
  sourceFile    String? // 업로드 파일명
  uploadBatchNo String? // 업로드 배치번호 (YYMMDDHHMMSS, 같은 업로드끼리 공유)
  autoCreatedFromShipment Boolean @default(false) // 출고 시 직접입력으로 자동 생성된 판번호

  // 외부 출고 시 어떤 ShipmentItem 에서 참조하는지 (SetNull 으로 출고취소 안전)
  shipmentItems ShipmentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([heatNo])
  @@index([vesselCode, material, thickness, width, length])
}

// ==========================================
// 외부 출고 시스템 — 강재 외부 납품 (거래명세서 자동출력)
// ==========================================
model Shipment {
  id           String         @id @default(cuid())
  shipmentNo   String         @unique // 예: SO-20260611-0001
  shippedAt    DateTime                // 출고일
  status       ShipmentStatus @default(ACTIVE)
  cancelledAt  DateTime?
  cancelReason String?
  createdBy    String?                 // 작성자 username (로그인 시스템 도입 후)
  memo         String?

  vehicles ShipmentVehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shippedAt])
  @@index([status])
}

model ShipmentVehicle {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  sequence    Int      // 1, 2, 3 …
  vehicleNo   String   // 차량번호
  driverName  String?
  driverPhone String?
  loadLimit   Float?   // 적재한도 (kg)
  totalWeight Float?   // 합계 중량 (kg)

  // 거래명세서 스냅샷 — 확정 시점 값 보존 (마스터 변경되어도 PDF 재출력 가능)
  supplierId       String?
  supplierSnapshot Json?
  deliveryId       String?
  deliverySnapshot Json?

  invoiceNo  String?  @unique // 거래명세서 번호 (예: 20260611-01 — 양식 형식)
  invoicedAt DateTime?

  // 거래명세서 양식 — 사용자 수동 입력 필드 (PDF 화면에서 인라인 편집)
  issueDate     DateTime? // 발행일자 (default = shippedAt)
  writerName    String?   // 작성(출고)자
  writerPhone   String?   // 작성자 연락처
  receiverName  String?   // 인수(입고)자

  items ShipmentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shipmentId])
}

model ShipmentItem {
  id              String @id @default(cuid())
  vehicleId       String
  vehicle         ShipmentVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  steelPlanId     String          // 한 SteelPlan 은 활성 출고장(ACTIVE)에서만 한 번 — application 레벨에서 강제 (cancel 시 ShipmentItem 보존 위해 DB unique 제거)
  steelPlan       SteelPlan @relation(fields: [steelPlanId], references: [id], onDelete: Restrict)
  steelPlanHeatId String?
  steelPlanHeat   SteelPlanHeat? @relation(fields: [steelPlanHeatId], references: [id], onDelete: SetNull)

  // 출고 시점 스냅샷 (자재 마스터 변경 무관 PDF 일관성)
  vesselCode   String
  material     String
  thickness    Float
  width        Float
  length       Float
  weight       Float
  block        String?  // 블록 (SteelPlan.reservedFor 스냅샷, 사용자 수정 가능)
  heatNo       String?  // 매칭/직접입력 판번호 텍스트 (양식의 "제품번호")
  manualHeatNo Boolean  @default(false)

  // 거래명세서 양식 — 사용자 수동 입력 (PDF 화면에서 인라인 편집)
  cutScheduledDate  DateTime? // 절단예정일
  classSociety      String?   // 선급 (KR/ABS/DNV/LR 등)
  drawingNo         String?   // 도면번호
  cuttingEquipment  String?   // 절단장비
  selectionOrderNo  String?   // 선별지시번호

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([steelPlanHeatId])
}


// ==========================================
// 절단파트 — 거래처(공급처 + 납품처) 관리
// 거래명세표 자동출력 데이터 소스 — "공급자"와 "공급받는자" 양쪽
//   SUPPLIER = 공급처 (우리 회사·자회사, 사업자등록증 불필요)
//   DELIVERY = 납품처 (절단·가공부재 납품받는 거래처, 사업자등록증 보관)
// 자재거래처(Vendor) 와는 별도 — 매출 측 거래처
// ==========================================
enum DeliveryVendorType {
  SUPPLIER // 공급처
  DELIVERY // 납품처
}

model DeliveryVendor {
  id                  String             @id @default(cuid())
  vendorType          DeliveryVendorType @default(DELIVERY)
  bizNo               String?            // 사업자등록번호 (예: 123-45-67890)
  name                String             // 상호 (필수)
  ceo                 String?            // 대표자
  address             String?            // 주소
  bizType             String?            // 업태
  bizItem             String?            // 종목
  phone               String?            // 회사 전화번호
  fax                 String?            // 팩스
  contactName         String?            // 업체담당자 이름 (납품처에서 의미)
  contactPhone        String?            // 업체담당자 전화번호 (납품처에서 의미)
  memo                String?            // 비고

  // 사업자등록증 — 납품처(DELIVERY) 만 사용, 업체당 1개
  bizCertStoredName   String?  // 디스크 저장명 (cuid.확장자)
  bizCertOriginalName String?  // 원본 파일명
  bizCertMimeType     String?  // image/* | application/pdf
  bizCertSize         Int?     // bytes

  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([vendorType])
  @@index([name])
}

// ==========================================
// 랜딩 페이지 달력 — 간단 일정 메모
// ==========================================
model CalendarEvent {
  id        String   @id @default(cuid())
  date      DateTime // 일정 날짜 (00:00:00 으로 정규화 저장)
  registrar String   // 등록자 이름
  content   String   // 일정 내용
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ==========================================
// 강재매칭 — 업로드 사양 목록을 강재전체목록과 매칭 (저장·재조회)
// ==========================================
model SteelMatchJob {
  id        String   @id @default(cuid())
  name      String   // 매칭 이름 (예: "4506호선 입고자재 매칭작업")
  author    String?  // 작성자
  statuses  String   @default("ALL") // 매칭 대상 상태: "ALL" 또는 콤마구분 (REGISTERED,RECEIVED,ISSUED,COMPLETED,SHIPPED_OUT)
  reservedFilter String @default("ANY") // 확정정보 필터: "ANY"(상관없이) | "NONE"(확정정보 없는것만)
  specs     Json     // 업로드 사양 목록 [{ vesselCode, material, thickness, width, length }]
  createdAt DateTime @default(now())

  @@index([createdAt])
}
