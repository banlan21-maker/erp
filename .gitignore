# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# 사용자 업로드 — git 추적 안 함 (NAS 볼륨 마운트로 영구화)
/public/uploads/

# PC 변환 도구 — venv 와 사용자 PDF/출력 엑셀은 추적 안 함
tools/pdf-to-excel/venv/
tools/pdf-to-excel/*.pdf
tools/pdf-to-excel/*_output.xlsx
tools/pdf-to-excel/__pycache__/

# docs 폴더의 엑셀 원본 양식/기성 파일 — 저장소에 커밋하지 않음 (양식 참고용 로컬 파일)
docs/*.xlsx

# 워크플로 조사용 임시 스크립트 (에이전트 생성, 일회성) — 커밋 안 함
scripts/wf-*.mjs
scripts/wf2-*.mjs
scripts/wf3-*.mjs
